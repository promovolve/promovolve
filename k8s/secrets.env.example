# Copy to k8s/secrets.env (gitignored) and fill in.
# Consumed by the `api-secret` secretGenerator in kustomization.yaml.

# Required — must match the db-secret password (default dev value).
JDBC_PASSWORD=promovolve

# Required — LLM provider for taxonomy classification. The API will NOT
# boot without one of GEMINI/OPENAI/ANTHROPIC (ClusterBootstrap hard-fails).
GEMINI_API_KEY=

# REQUIRED — Cloudflare R2 for creative asset storage. The API hard-fails
# at startup if any of these are missing (no in-memory fallback).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# NOTE: CDN_BASE_URL and BANNER_SCRIPT_URL are NOT secrets — they're public R2
# URLs, tracked in kustomization.yaml's api-config configMap. Set/update them
# there (CDN_BASE_URL = your R2 public origin; BANNER_SCRIPT_URL bumps on each
# `banner-component` R2 publish). Only true secrets live in this file.

# Optional but recommended — shared secret gating the core's /v1/internal
# billing endpoints (metering, advertiser suspend/resume). When set, the
# platform must send the SAME value (see platform-secrets.env.example).
# Unset = the internal endpoints trust network isolation.
INTERNAL_API_KEY=
