# PromoVolve development environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Cloudflare R2 storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=promovolve
CDN_BASE_URL=

# Where the <expandable-magazine-banner> web component is fetched from.
# Point at the R2-hosted bundle (see platform/banner-component/README.md)
# in prod; leave unset to fall back to the API's classpath-served copy.
BANNER_SCRIPT_URL=

# LLM API keys
GEMINI_API_KEY=
