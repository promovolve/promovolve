{
  "name": "High Traffic Pacing Test",
  "description": "High request rate to stress-test pacing algorithm",

  "setup": {
    "mode": "performance",
    "advertisers": 1,
    "campaignsPerAdvertiser": 1,
    "creativesPerCampaign": 3,
    "category": "perf-test",
