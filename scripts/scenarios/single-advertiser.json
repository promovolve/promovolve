{
  "name": "Single Advertiser (Monopoly)",
  "description": "1 advertiser — floor IS the clearing price. Tests how floor agent handles a monopoly market over 10 simulated days",

  "setup": {
    "mode": "pacing",
    "advertisers": 1,
    "campaignsPerAdvertiser": 1,
    "creativesPerCampaign": 3,
    "adProductCategory": "1529",
    "additionalCategories": ["653", "654", "655"],
    "budget": 30.0,
    "cpm": 5.0,
    "userPoolSize": 200
  },
  "pacing": {
    "dayDurationSeconds": 300,
    "weekdayShapeVolumes": [
      0.5, 0.3, 0.2, 0.2, 0.3, 0.5,
      0.8, 1.5, 2.0, 2.5, 2.5, 2.0,
      1.8, 2.0, 2.2, 2.5, 3.0, 2.5,
      2.0, 1.5, 1.0, 0.8, 0.6, 0.4
    ]
  },
  "traffic": {
    "continuous": true,
    "reportEvery": 300,
    "clickRate": 0.04,
    "variableDelay": false,
    "delayMs": 15,
    "stopAfterDays": 10
  }
}
